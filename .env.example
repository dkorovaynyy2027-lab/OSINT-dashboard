# =========================================================
# OSINT Platform — environment variables
# Copy to .env (root) and adjust. docker-compose reads from this file.
# =========================================================

# ---- Core ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WS_URL=ws://localhost:4000

# ---- Postgres ----
POSTGRES_USER=osint
POSTGRES_PASSWORD=osint_dev_password_change_me
POSTGRES_DB=osint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://osint:osint_dev_password_change_me@postgres:5432/osint?schema=public

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- OpenSearch (full-text search across entities/findings) ----
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://opensearch:9200

# ---- Auth ----
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_me_with_random_48_byte_secret
JWT_REFRESH_SECRET=replace_me_with_another_random_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
BCRYPT_ROUNDS=12
TOTP_ISSUER=OSINT-Platform

# ---- Rate limiting (per-IP defaults; per-route configurable) ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ---- Provider API keys (all free tiers; leave blank to disable a provider) ----
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
HIBP_API_KEY=
HUNTER_API_KEY=
INTELX_API_KEY=
URLSCAN_API_KEY=
SECURITYTRAILS_API_KEY=
GREYNOISE_API_KEY=

# ---- Logging ----
LOG_LEVEL=info

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:3000
